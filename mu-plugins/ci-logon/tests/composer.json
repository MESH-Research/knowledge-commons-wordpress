{
    "name": "mesh-research/ci-logon",
    "description": "CI Logon authentication plugin for WordPress",
    "type": "wordpress-muplugin",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Mesh Research",
            "email": "info@meshresearch.net"
        }
    ],
    "require": {
        "php": ">=7.4"
    },
    "require-dev": {
        "../../../vendor/phpunit/phpunit": "^9.5",
        "../../../vendor/mockery/mockery": "^1.4"
    },
    "autoload": {
        "psr-4": {
            "MeshResearch\\CILogon\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "MeshResearch\\CILogon\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "../../../vendor/bin/phpunit --configuration=tests/phpunit.xml",
        "test-coverage": "../../../vendor/bin/phpunit --configuration=tests/phpunit.xml --coverage-html=tests/coverage-report",
        "test-verbose": "../../../vendor/bin/phpunit --configuration=tests/phpunit.xml -v"
    }
}
