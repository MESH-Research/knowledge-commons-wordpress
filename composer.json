{
  "name": "mesh-research/knowledge-commons",
  "type": "project",
  "license": "MIT",
  "description": "The Humanities Commons / Knowledge Commons WordPress site.",
  "homepage": "https://hcommons.org/",
  "authors": [
    {
      "name": "Mike Thicke",
      "email": "thickemi@msu.edu"
    }
  ],
  "keywords": [
    "wordpress"
  ],
  "repositories": [
    {
      "type": "composer",
      "url": "https://repo.wp-packages.org",
      "only": [
        "wp-plugin/*",
        "wp-theme/*"
      ]
    },
    {
      "type": "vcs",
      "url": "https://github.com/MESH-Research/kcworks-on-wp"
    },
    {
      "type": "path",
      "url": "simplesamlphp/idpsamlmdattributes"
    }
  ],
